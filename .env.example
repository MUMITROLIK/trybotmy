WEB_SERVER_URL=http://localhost:8001
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
NETLIFY_TOKEN=your_netlify_token_here
NETLIFY_SITE_ID=your_netlify_site_id_here
CRYPTOPANIC_API_KEY=your_cryptopanic_api_key_here

# ── Торговля ──────────────────────────────────────────────────────────────────
AUTO_TAKE_SIGNALS=true
MIN_SIGNAL_STRENGTH=60
SCAN_INTERVAL_SECONDS=60
TOP_FUTURES_COUNT=120
MIN_VOLUME_USDT=15000000
MAX_OPEN_POSITIONS=20
MAX_LONG_PER_SCAN=0
MAX_SHORT_PER_SCAN=0

# ── Bybit ─────────────────────────────────────────────────────────────────────
BYBIT_TOP_COUNT=70
BYBIT_MIN_VOLUME_USDT=300000

# ── ML — режим сбора данных (включить обратно через 2-3 дня) ──────────────────
ML_FILTER_ENABLED=false
ML_FILTER_MIN_PROB=0.52
ML_FILTER_MIN_ROWS=200

# ── Тайминги сделок ───────────────────────────────────────────────────────────
SIGNAL_TTL_MINUTES=240
LIMIT_ORDER_TTL_MINUTES=60
SL_COOLDOWN_MINUTES=60

# ── Фильтры сигналов (смягчены для сбора данных) ─────────────────────────────
MIN_ATR_PCT_FOR_SIGNAL=0.20
MAX_TP1_ATR_MULT_FOR_SIG=4.00
ENTRY_CANDLE_MAX_ATR_MULT=2.0

# ── Лимитные входы ────────────────────────────────────────────────────────────
LIMIT_CHASE_MAX_PCT=2.0
LIMIT_CHASE_MIN_WAIT_MIN=5.0

# ── Скан ──────────────────────────────────────────────────────────────────────
SCAN_BATCH_SIZE=5